CREATE PROCEDURE AddProduct
    @name NVARCHAR(100),
    @desc NVARCHAR(255),
    @catid INT,
    @price DECIMAL(10,2)
AS
BEGIN
    INSERT INTO Products (PRODUCTSNAME, DESCRIPTION, CATEGORIESID, PRICE)
    VALUES (@name, @desc, @catid, @price);
END;




