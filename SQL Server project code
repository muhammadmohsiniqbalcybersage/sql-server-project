12.3 Triggers
Automatic inventory update after order placement
--TRIGGER ATUOMATE THE INVENTORY STORCK AUTOMATIALLY WHEN PRODUCT IS ORDERES


CREATE TRIGGER trg_UpdateInventory
ON OrdersItem
AFTER INSERT
AS
BEGIN
    UPDATE Inventory
    SET QUANTITYAVAILABLE = QUANTITYAVAILABLE - i.QUANTITY
    FROM Inventory inv
    JOIN inserted i ON inv.PRODUCTSID = i.PRODUCTSID;
END;
