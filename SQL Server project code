Tables Implemented

-- 1.Users table

CREATE TABLE Users(

USERID INT PRIMARY KEY,
FULLNAME NVARCHAR(100),
EMAIL NVARCHAR(100) UNIQUE,
PHONENAME NVARCHAR (11),
CREATEAT DATETIME DEFAULT GETDATE()
);

--2.ADDRESSES Table

CREATE TABLE Addresses (
    ADDRESSESID INT PRIMARY KEY,
    USERID INT FOREIGN KEY REFERENCES Users(USERID),
    ADDRESSLINE NVARCHAR(255),
    CITY NVARCHAR(100) UNIQUE,
    STATE NVARCHAR(100),
    PINCODE NVARCHAR(10),
    CREATEDAT DATETIME DEFAULT GETDATE()
);

--3.Vendors Table
CREATE TABLE Vendors (
    VENDORID INT PRIMARY KEY,
    VENDORNAME NVARCHAR(255),
    CONTACTMAIL NVARCHAR(100),
    CREATEDAT DATETIME DEFAULT GETDATE()
);

--4. ProductCategories Table
CREATE TABLE ProductCategories (
    CATEGORIESID INT PRIMARY KEY,
    CATEGORIESNAME NVARCHAR(100) NOT NULL,
    
);

  
--5.PRODUCTS TABLE 
CREATE TABLE Products(
    PRODUCTSID INT PRIMARY KEY IDENTITY(1,1),
    PRODUCTSNAME  NVARCHAR(100) NOT NULL,
    DESCRIPTION NVARCHAR(255),
    CATEGORIESID INT FOREIGN KEY REFERENCES ProductCategories(CATEGORIESID),
    PRICE DECIMAL (10,2) ,
    CREATEDAT DATETIME DEFAULT GETDATE()
);

--6.INVENTORY TABLE 
CREATE TABLE Inventory(
    INVENTORYID INT PRIMARY KEY,
    VENDORID INT FOREIGN KEY REFERENCES Vendors(VENDORID),
    PRODUCTSID INT FOREIGN KEY REFERENCES Products(PRODUCTSID),
    QUANTITYAVAILABLE INT  ,
    LASTUPDATED DATETIME DEFAULT GETDATE()
);

--7. ORDERS TABLE 
CREATE TABLE Orders (
    ORDERSID INT PRIMARY KEY IDENTITY(1,1),
    VENDORID INT FOREIGN KEY REFERENCES Vendors(VENDORID),
    USERID INT FOREIGN KEY REFERENCES Users(USERID),
    ORDERUPDATE DATETIME DEFAULT GETDATE(),
    TOTALAMOUNT DECIMAL(10,2)
);


-- 8.ORDERS TABLE 
CREATE TABLE OrdersItem (
    ORDERSITEMID INT PRIMARY KEY,
    ORDERSID INT FOREIGN KEY REFERENCES Orders(ORDERSID),
    PRODUCTSID INT FOREIGN KEY REFERENCES Products(PRODUCTSID),
    QUANTITY INT,
    PRICE DECIMAL(10,2)
);

--9.Payments Table 

CREATE TABLE Payments (
    PAYMENTID INT PRIMARY KEY,
    ORDERSID INT FOREIGN KEY REFERENCES Orders(ORDERSID),
    PAYMENTMODE NVARCHAR(50),
    PAYMENTSTATUS NVARCHAR(50),
